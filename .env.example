# Copy to `.env` at repo root (gitignored). Never commit real secrets.

# --- PostgreSQL (required for Prisma + Shopify session storage) ---
# Replace USER, PASSWORD, HOST, PORT, DATABASE with your Postgres credentials.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example — local docker-compose Postgres in this repo:
# DATABASE_URL=postgresql://listingfix:listingfix_dev_local@localhost:5432/listingfix

# --- OpenAI (optional; AI suggestions in app modal) ---
OPENAI_API_KEY=your_openai_api_key_here

# Optional — defaults to gpt-4o-mini if unset.
# OPENAI_MODEL=gpt-4o-mini

# --- Shopify ---
# `shopify app dev` injects most of these; set manually if you run the server without the CLI.
#
# SHOPIFY_APP_URL=https://YOUR_DEV_TUNNEL_URL
# SHOPIFY_API_KEY=<Client ID from Partners>
# SHOPIFY_API_SECRET=<Client secret from Partners>
# SCOPES=read_products,write_products
#
# Production (Railway Variables): use your public HTTPS app URL, no trailing slash.
# SHOPIFY_APP_URL=https://YOUR-SERVICE.up.railway.app
#
# Optional:
# SHOP_CUSTOM_DOMAIN=...
