// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ShopUsageDaily {
  id                String   @id @default(cuid())
  shop              String
  usageDate         DateTime @db.Date
  scanCount         Int      @default(0)
  aiGenerationCount Int      @default(0)
  applyCount        Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shop, usageDate])
  @@index([shop])
}

model BetaFeedback {
  id            String   @id @default(cuid())
  shopDomain    String
  feedbackType  String
  message       String
  optionalEmail String?
  appVersion    String?
  currentRoute  String?
  browserInfo   String?
  createdAt     DateTime @default(now())

  @@index([shopDomain])
  @@index([createdAt])
}

model CatalogScanSession {
  id                  String    @id @default(cuid())
  shopDomain          String
  scanStartedAt       DateTime
  scanCompletedAt     DateTime?
  productCount        Int       @default(0)
  issueCount          Int       @default(0)
  averageScore        Int?
  scanSummary         String?
  scanResultsJson     Json
  catalogFingerprint  String?
  dashboardFilterJson Json?
  scanDurationMs      Int?
  topIssue            String?
  improvementCount    Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shopDomain, scanCompletedAt])
}
